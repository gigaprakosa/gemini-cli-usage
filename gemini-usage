#!/usr/bin/env python3
import json
import glob
import os
from pathlib import Path
from collections import defaultdict
from datetime import datetime

def parse_session_file(filepath):
    usage_data = []
    try:
        with open(filepath, 'r') as f:
            for line in f:
                try:
                    data = json.loads(line)
                    if data.get('type') == 'gemini' and 'tokens' in data:
                        timestamp = data.get('timestamp')
                        month = timestamp[:7] if timestamp else "unknown"
                        usage_data.append({
                            'month': month,
                            'model': data.get('model', 'unknown'),
                            'input': data['tokens'].get('input', 0),
                            'output': data['tokens'].get('output', 0),
                            'cached': data['tokens'].get('cached', 0),
                            'thoughts': data['tokens'].get('thoughts', 0)
                        })
                except:
                    continue
    except:
        pass
    return usage_data

def get_all_usage():
    all_usage = []
    base_dir = Path.home() / ".gemini/tmp"
    chat_files = glob.glob(str(base_dir / "**/chats/*.jsonl"), recursive=True)
    for f in chat_files:
        all_usage.extend(parse_session_file(f))
    return all_usage

def aggregate_usage(usage_list):
    # month -> model -> stats
    aggregated = defaultdict(lambda: defaultdict(lambda: {
        'input': 0, 'output': 0, 'cached': 0, 'thoughts': 0, 'total': 0
    }))
    
    for item in usage_list:
        m = item['month']
        model = item['model']
        aggregated[m][model]['input'] += item['input']
        aggregated[m][model]['output'] += item['output']
        aggregated[m][model]['cached'] += item['cached']
        aggregated[m][model]['thoughts'] += item['thoughts']
        aggregated[m][model]['total'] += (item['input'] + item['output'] + item['cached'] + item['thoughts'])
        
    return aggregated

# Official Google Gemini API Pricing (May 2026 Reference)
# Prices per 1,000,000 tokens (USD)
MODEL_PRICING = {
    "gemini-3.1-flash": {"input": 0.50, "output": 3.00},
    "gemini-3.1-flash-lite": {"input": 0.25, "output": 1.50},
    "gemini-3.1-pro": {"input": 2.00, "output": 12.00},
    "gemini-2.5-flash": {"input": 0.30, "output": 2.50},
    "gemini-2.5-pro": {"input": 1.25, "output": 10.00},
    "default": {"input": 0.50, "output": 3.00}          # Default to Gemini 3 Flash
}

def get_pricing_for_model(model_name):
    model_name = model_name.lower()
    
    # Exact matches for May 2026 model strings
    if "3.1-flash-lite" in model_name: return MODEL_PRICING["gemini-3.1-flash-lite"]
    if "3.1-flash" in model_name:      return MODEL_PRICING["gemini-3.1-flash"]
    if "3-flash" in model_name:        return MODEL_PRICING["gemini-3.1-flash"]
    if "3.1-pro" in model_name:        return MODEL_PRICING["gemini-3.1-pro"]
    if "3-pro" in model_name:          return MODEL_PRICING["gemini-3.1-pro"]
    if "auto-gemini-3" in model_name:  return MODEL_PRICING["gemini-3.1-flash"]
    
    # Older versions
    if "2.5-flash" in model_name:      return MODEL_PRICING["gemini-2.5-flash"]
    if "2.5-pro" in model_name:        return MODEL_PRICING["gemini-2.5-pro"]
    
    # Generic keywords
    if "flash" in model_name:          return MODEL_PRICING["gemini-3.1-flash"]
    if "pro" in model_name:            return MODEL_PRICING["gemini-3.1-pro"]
    
    return MODEL_PRICING["default"]

def calculate_cost(model_name, stats):
    pricing = get_pricing_for_model(model_name)
    
    # May 2026 Billing Rules:
    # 1. Standard Input tokens
    input_cost = (stats['input'] / 1_000_000) * pricing["input"]
    
    # 2. Cache Read tokens are billed at 10% of base input price
    cache_read_cost = (stats['cached'] / 1_000_000) * (pricing["input"] * 0.10)
    
    # 3. Thought tokens (Reasoning) are billed at Output rate
    thought_cost = (stats['thoughts'] / 1_000_000) * pricing["output"]
    
    # 4. Standard Output tokens
    output_cost = (stats['output'] / 1_000_000) * pricing["output"]
    
    return input_cost + cache_read_cost + thought_cost + output_cost

def print_table(aggregated):
    months = sorted(aggregated.keys())
    
    if len(months) == 1:
        print("📊 Gemini CLI Usage:")
    else:
        print(f"📊 Gemini CLI Usage (last {len(months)} months):")
        
    for month in months:
        monthly_total_tokens = 0
        monthly_total_cost = 0.0
        
        for model_name, stats in aggregated[month].items():
            monthly_total_tokens += stats['total']
            monthly_total_cost += calculate_cost(model_name, stats)
            
        print(f"• {month}: {monthly_total_tokens:,} tokens, Cost: ${monthly_total_cost:.2f}")

if __name__ == "__main__":
    usage = get_all_usage()
    if not usage:
        print("No usage data found.")
    else:
        agg = aggregate_usage(usage)
        print_table(agg)
